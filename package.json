{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "dev": "pnpm -r --if-present run dev",
    "start": "pnpm -r --if-present run start",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "watch": "node scripts/watch-backend.js",
    "auto-reload": "concurrently \"node scripts/watch-backend.js\" \"pnpm --filter @workspace/nashmi-store dev\" \"pnpm --filter @workspace/nashmi-admin dev\""
  },
  "private": true,
  "devDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.60.3",
    "@tailwindcss/oxide-win32-x64-msvc": "^4.2.4",
    "concurrently": "^9.2.1",
    "lightningcss-win32-x64-msvc": "^1.32.0",
    "pg-cloudflare": "^1.3.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
